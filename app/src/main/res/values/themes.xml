<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ElibraryPetik" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main Brand Colors -->
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorPrimaryVariant">@color/primary_blue_light</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_blue</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorOnSecondaryFixed">@color/white</item>
        <item name="colorOnSecondaryFixedVariant">@color/blue</item>
        <item name="colorPrimaryFixed">@color/accent_blue</item>
        
        <!-- Background and Surface -->
        <item name="android:windowBackground">@color/background_light</item>
        <item name="colorSurface">@color/surface_white</item>

        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:textColorLink">@color/accent_blue</item>

        <item name="colorOnSecondaryContainer">@color/search_bg</item>
        <item name="colorOnBackground">@color/primary_blue</item>


        <item name="colorControlNormal">@color/black</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/primary_blue</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Custom font for the whole app if needed -->
        <item name="fontFamily">@font/poppins_regular</item>

        <item name="drawerArrowStyle">@style/DrawerIconStyle</item>

        <item name="chipStyle">@style/CustomChipStyle</item>
    </style>

    <style name="Theme.ElibraryPetik" parent="Base.Theme.ElibraryPetik" />

    <!-- Style for Toolbar Titles -->
    <style name="ToolbarTitleStyle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">?attr/colorOnSecondary</item>
    </style>

    <!-- Custom Chip Style -->
    <style name="CustomChipStyle" parent="Widget.Material3.Chip.Filter">
        <!-- Gunakan selector background -->
        <item name="chipBackgroundColor">@color/chip_background_selector</item>

        <!-- Gunakan selector teks agar warna teks ikut berubah -->
        <item name="android:textColor">@color/chip_text_selector</item>
        
        <item name="checkedIconVisible">false</item>

        <!-- Warna Garis Pinggir (opsional) -->
        <item name="chipStrokeColor">?attr/colorPrimaryFixed</item>
        <item name="chipStrokeWidth">1dp</item>

        <!-- Padding dalam chip -->
        <item name="chipStartPadding">12dp</item>
        <item name="chipEndPadding">12dp</item>
        
        <!-- Font -->
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="DrawerIconStyle" parent="Widget.AppCompat.DrawerArrowToggle">
        <item name="color">?attr/colorOnPrimary</item>
    </style>
</resources>