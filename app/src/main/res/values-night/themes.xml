<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ElibraryPetik" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Main Brand Colors -->
        <item name="colorPrimary">@color/primary_blue_mode_dark</item>
        <item name="colorPrimaryVariant">@color/primary_blue_light_mode_dark</item>
        <item name="colorOnPrimary">@color/white_mode_dark</item>
        <item name="colorPrimaryFixed">@color/accent_blue_mode_dark</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_blue_mode_dark</item>
        <item name="colorOnSecondary">@color/white_mode_dark</item>
        <item name="colorOnSecondaryFixed">@color/blue_mode_dark</item>
        <item name="colorOnSecondaryFixedVariant">@color/blue_mode_dark</item>

        <!-- Background and Surface -->
        <item name="android:windowBackground">@color/background_dark_mode_dark</item>
        <item name="colorSurface">@color/surface_dark_mode_dark</item>

        <item name="colorOnSecondaryContainer">@color/search_bg_mode_dark</item>
        <item name="colorOnBackground">#5A81D5</item>

        <item name="android:textColorPrimary">@color/text_primary_mode_dark</item>
        <item name="android:textColorSecondary">@color/text_secondary_mode_dark</item>
        <item name="android:textColorHint">@color/text_hint_mode_dark</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/primary_blue_light_mode_dark</item>


        <item name="colorControlNormal">@color/white</item>

        <item name="drawerArrowStyle">@style/DrawerIconStyle</item>

        <item name="chipStyle">@style/CustomChipStyle</item>
    </style>
</resources>