<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_white"
    tools:context=".ui.bantuan.FaqDetailFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_faq_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_bold"
            android:text="@string/judul_pertanyaan"
            android:textColor="@color/primary_blue"
            android:textSize="20sp" />

        <View
            android:layout_width="60dp"
            android:layout_height="4dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp"
            android:background="@color/accent_blue" />

        <TextView
            android:id="@+id/tv_faq_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_regular"
            android:lineSpacingExtra="6dp"
            android:text="@string/ini_adalah_isi_jawaban_dari_pertanyaan_yang_diklik_penjelasan_akan_muncul_di_sini_secara_detail_agar_pengguna_memahami_informasi_yang_diberikan"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>